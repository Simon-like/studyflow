{
  "cli": {
    "version": ">= 18.3.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "NODE_ENV": "development"
      },
      "preInstallCommand": "bash eas-hooks/eas-build-pre-install.sh",
      "onSuccessCommand": "bash eas-hooks/eas-build-on-success.sh"
    },
    "development-simulator": {
      "developmentClient": true,
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      },
      "preInstallCommand": "bash eas-hooks/eas-build-pre-install.sh",
      "onSuccessCommand": "bash eas-hooks/eas-build-on-success.sh"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "preInstallCommand": "bash eas-hooks/eas-build-pre-install.sh",
      "onSuccessCommand": "bash eas-hooks/eas-build-on-success.sh"
    },
    "production": {
      "autoIncrement": true,
      "preInstallCommand": "bash eas-hooks/eas-build-pre-install.sh",
      "onSuccessCommand": "bash eas-hooks/eas-build-on-success.sh"
    }
  },
  "submit": {
    "production": {}
  }
}
