{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@studyflow/shared": ["../../packages/shared/src"],
      "@studyflow/shared/*": ["../../packages/shared/src/*"],
      "@studyflow/api": ["../../packages/api/src"],
      "@studyflow/api/*": ["../../packages/api/src/*"]
    },
    "skipLibCheck": true
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "android", "ios", "metro.config.js"]
}
