# ==========================================
# StudyFlow Web 环境配置示例
# 复制为 .env.development 或 .env.local 使用
# ==========================================

# API 基础地址（不包含 /api/v1 后缀，由前端拼接完整路径）
# Mock 模式: http://localhost:8080 (任意值，不实际发出请求)
# 后端模式:  http://localhost:3001
VITE_API_BASE_URL=http://localhost:3001

# 是否使用 Mock 数据 (true/false)
VITE_USE_MOCK=false

# 应用信息
VITE_APP_NAME=StudyFlow
VITE_APP_VERSION=1.0.0
