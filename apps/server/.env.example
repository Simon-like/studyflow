# ==========================================
# StudyFlow Server 环境变量配置
# ==========================================

# 应用配置
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1
API_VERSION=v1

# 数据库配置 (PostgreSQL)
DATABASE_URL="postgresql://studyflow:studyflow_password@localhost:5432/studyflow?schema=public"

# Redis 配置
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=

# JWT 配置
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_ACCESS_EXPIRATION="2h"
JWT_REFRESH_EXPIRATION="7d"

# 密码加密
BCRYPT_ROUNDS=12

# CORS 配置
CORS_ORIGIN="http://localhost:5173,http://localhost:19006"
CORS_CREDENTIALS=true

# 日志配置
LOG_LEVEL=debug
LOG_FORMAT=dev

# 上传配置
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads

# 外部 API
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
