{
  "name": "@studyflow/theme",
  "version": "1.0.0",
  "private": true,
  "description": "StudyFlow 设计系统 - 跨平台主题配置",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./adapters": {
      "types": "./src/adapters.ts",
      "default": "./src/adapters.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "src/**",
    "dist/**"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@studyflow/eslint-config": "workspace:*",
    "@studyflow/typescript-config": "workspace:*",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
