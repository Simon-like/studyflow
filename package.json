{
  "name": "studyflow",
  "version": "1.0.0",
  "description": "StudyFlow - 智能学习陪伴应用",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter=./packages/* --filter=!@studyflow/ui",
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@studyflow/web",
    "dev:mobile": "turbo run dev --filter=@studyflow/mobile",
    "dev:server": "turbo run dev --filter=@studyflow/server",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "clean:cache": "turbo run clean && rm -rf .turbo node_modules/.cache",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=docs^... && changeset publish",
    "setup": "bash tooling/scripts/setup.sh",
    "db:generate": "pnpm --filter @studyflow/server db:generate",
    "db:migrate": "pnpm --filter @studyflow/server db:migrate",
    "db:studio": "pnpm --filter @studyflow/server db:studio",
    "db:seed": "pnpm --filter @studyflow/server db:seed",
    "db:reset": "pnpm --filter @studyflow/server db:reset",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.16.1",
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "prettier": "^3.1.1",
    "turbo": "^1.13.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.2.0",
      "react-dom": "^19.2.0"
    },
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "bcrypt",
      "@nestjs/core"
    ]
  }
}
