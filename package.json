{
  "name": "studyflow",
  "version": "1.0.0",
  "description": "StudyFlow - 智能学习陪伴应用",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter=./packages/* --filter=!@studyflow/ui",
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@studyflow/web",
    "dev:mobile": "turbo run dev --filter=@studyflow/mobile",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "clean:cache": "turbo run clean && rm -rf .turbo node_modules/.cache",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=docs^... && changeset publish",
    "setup": "bash tooling/scripts/setup.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.16.1",
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "prettier": "^3.1.1",
    "turbo": "^1.13.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
